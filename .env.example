# Server-only variables (set in Vercel / Netlify project env or `.env.local`).
# Never prefix these with NEXT_PUBLIC_ — they must not ship to the browser.

# Required for production builds and for newsletter / Supabase API routes
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_KEY=

# Optional — enables /api/spotify when all three are set
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
